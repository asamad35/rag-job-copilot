{
  "manifest_version": 3,
  "name": "Autofill V1 Test",
  "description": "Detect form fields and fill them with deterministic test values.",
  "version": "1.0.0",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Autofill V1"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ]
}
